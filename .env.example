# Yandex Cloud Search API v2
YANDEX_SEARCH_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_SEARCH_URL=https://searchapi.api.cloud.yandex.net/v2/web/search

# Yandex AI Studio. Если ключ пустой, используется YANDEX_SEARCH_API_KEY.
# Для отдельного ключа сервисному аккаунту нужна роль ai.languageModels.user.
YANDEX_AI_API_KEY=
LLM_BASE_URL=https://ai.api.cloud.yandex.net/v1
LLM_MODEL=gpt://{folder_id}/aliceai-llm-flash

REQUEST_TIMEOUT=30
SEARCH_RESULTS=8

# Авторизация владельца сервиса
AUTH_USERNAME=admin
AUTH_PASSWORD=
# Сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=
AUTH_SESSION_HOURS=24
# В production за HTTPS установите true
AUTH_COOKIE_SECURE=false
